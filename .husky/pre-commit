#!/bin/sh

# Validate plugin structure before commit
# Version auto-bumps via post-commit hook when plugin files change

.husky/validate-plugin.sh || exit 1

# Typecheck and lint the site if any site files changed
if git diff --cached --name-only | grep -q '^site/'; then
  echo "Site files changed — running typecheck and lint..."
  pnpm --dir site typecheck || exit 1
  pnpm --dir site lint || exit 1
fi
